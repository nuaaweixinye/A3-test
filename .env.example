# ===================== Spark LLM =====================
# Preferred: Spark X1.5 / X2 WebSocket API.
# The app requires a real Spark credential. Missing credentials will raise an error.
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_WS_URL=wss://spark-api.xf-yun.com/x2
SPARK_DOMAIN=spark-x
SPARK_THINKING=disabled
SPARK_MAX_TOKENS=4096

# Optional fallback: Spark OpenAI-compatible HTTP endpoint.
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_DEFAULT_MODEL=4.0Ultra

# Optional per-stage model routing.
MODEL_ROUTES={"profile":"lite","planner":"4.0Ultra","doc":"4.0Ultra","video":"4.0Ultra","quiz":"4.0Ultra","tutor":"4.0Ultra","eval":"pro"}
# Optional per-stage WebSocket domain routing.
# SPARK_DOMAIN_ROUTES={"profile":"spark-x","planner":"spark-x","doc":"spark-x","design":"spark-x","video":"spark-x","quiz":"spark-x","mindmap":"spark-x","code":"spark-x","reading":"spark-x","tutor":"spark-x","eval":"spark-x"}

# ===================== App Auth / Database =====================
JWT_SECRET=change-me-to-a-random-string
DATABASE_URL="file:./dev.db"

# ===================== Knowledge Base =====================
# Optional Spark ChatDoc / knowledge-base settings.
# SPARK_KB_REPO_ID=

# ===================== Real MP4 Rendering =====================
# Install ffmpeg and add it to PATH, or set an absolute path here.
# Windows example:
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=

# ===================== TTS Reservation =====================
# Later this can be used to render narration audio into mp4 videos.
# TTS_SPARK_APPID=
# TTS_SPARK_API_KEY=
# TTS_SPARK_API_SECRET=
