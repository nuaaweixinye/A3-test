# ===================== 讯飞星火大模型（OpenAI 兼容接口）=====================
# 出题企业：科大讯飞（赛题硬性要求 AI 辅助工具须选用讯飞相关工具）
# 控制台：https://www.xfyun.cn/  → 创建"星火大模型"应用，获取 APIKey（即接口密钥/APIPassword）
# 未填写 SPARK_API_KEY 时，系统自动进入 mock 模式（输出占位内容），便于先联调 UI。

SPARK_API_KEY=
# 兼容端点地址（一般无需修改）
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
# 默认模型（星火模型 ID：4.0Ultra / generalv3.5 / pro / max / lite 等）
SPARK_DEFAULT_MODEL=4.0Ultra

# 分阶段模型路由（JSON）：不同任务阶段调用不同模型——画像抽取用轻量模型，
# 资源生成/辅导用强模型。参考 OpenMAIC 的 MODEL_ROUTES 设计。
MODEL_ROUTES={"profile":"lite","planner":"4.0Ultra","doc":"4.0Ultra","tutor":"4.0Ultra","eval":"pro"}

# ===================== 讯飞 TTS（后续教学视频/语音辅导加分项预留）=====================
# TTS_SPARK_APPID=
# TTS_SPARK_API_KEY=
# TTS_SPARK_API_SECRET=

JWT_SECRET=change-me-to-a-random-string
DATABASE_URL="file:./dev.db"

# ===================== 讯飞星火知识库 (ChatDoc) =====================
# 云端 RAG 检索（knowledge-lib 内置默认值，正常使用可不填）
# SPARK_APP_ID=
# SPARK_API_SECRET=
# SPARK_KB_REPO_ID=
